{
  "preset": "Solo1080p",
  "snapshot_path": "automation/live-snapshot.json",
  "snapshot_provider": "browser_cdp",
  "browser": {
    "node_command": "node",
    "chrome_path": "",
    "cdp_port": 9222,
    "url": "https://tetr.io/",
    "target_hint": "TETR.IO",
    "connect_only": false,
    "probe_page_state": true,
    "debugger_probe_mode": "manual",
    "state_poll_ms": 40,
    "min_state_poll_ms": 16,
    "use_ribbon_websocket": true,
    "ribbon_decode_mode": "until_seed",
    "use_seed_simulation_fallback": false,
    "input_focus_mode": "per_plan",
    "player_selector": "auto",
    "player_nickname": "",
    "player_user_id": "",
    "dump_state_on_fail": true,
    "dump_state_path": "automation/debug/tetrio-state-dump.json",
    "bootstrap_timeout_ms": 2500
  },
  "always_on_top": false,
  "dry_run": false,
  "poll_interval_ms": 20,
  "perf_log_enabled": true,
  "input_backend": "scan_code",
  "target_pps": 0.0,
  "tap_duration_ms": 60,
  "movement_tap_duration_ms": 20,
  "rotate_tap_duration_ms": 30,
  "hold_tap_duration_ms": 30,
  "hard_drop_tap_duration_ms": 40,
  "soft_drop_tap_duration_ms": 20,
  "movement_interval_ms": 20,
  "rotation_interval_ms": 30,
  "piece_interval_ms": 60,
  "hard_drop_interval_ms": 40,
  "min_snapshot_age_ms": 30,
  "bot": {
    "threads": 1,
    "min_nodes": 0,
    "max_nodes": 100000,
    "use_hold": true,
    "speculate": false,
    "movement_mode": "zero_g_safe",
    "spawn_rule": "row19_or20"
  },
  "handling": {
    "arr_ms": 0,
    "das_ms": 97,
    "dcd_ms": 0,
    "soft_drop_mode": "infinite",
    "allow_post_softdrop_actions": true,
    "allow_post_softdrop_horizontal": false,
    "release_after_each_action": false,
    "action_settle_ms": 0,
    "soft_drop_factor": 1,
    "prevent_accidental_hard_drops": true,
    "cancel_das_on_direction_change": true,
    "prefer_soft_drop_over_movement": false,
    "irs_mode": "off",
    "ihs_mode": "off"
  },
  "keys": {
    "left": "LEFT",
    "right": "RIGHT",
    "rotate_cw": "X",
    "rotate_ccw": "Z",
    "hold": "C",
    "soft_drop": "DOWN",
    "hard_drop": "SPACE"
  }
}
