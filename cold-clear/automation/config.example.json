{
  "snapshot_provider": "browser_cdp",
  "snapshot_path": "automation/live-snapshot.json",
  "dry_run": true,
  "poll_interval_ms": 4,
  "target_pps": 0.0,
  "tap_duration_ms": 60,
  "movement_tap_duration_ms": 25,
  "rotate_tap_duration_ms": 28,
  "hold_tap_duration_ms": 35,
  "hard_drop_tap_duration_ms": 30,
  "soft_drop_tap_duration_ms": 25,
  "movement_interval_ms": 0,
  "rotation_interval_ms": 8,
  "piece_interval_ms": 0,
  "hard_drop_interval_ms": 0,
  "min_snapshot_age_ms": 0,
  "input_backend": "browser_cdp",
  "scanner": {
    "config_path": "automation/scan-config.vs-left-1080p.json",
    "python_command": "python"
  },
  "browser": {
    "node_command": "node",
    "chrome_path": "",
    "cdp_port": 9222,
    "url": "https://tetr.io/",
    "target_hint": "TETR.IO",
    "connect_only": false,
    "probe_page_state": true,
    "use_ribbon_websocket": true,
    "use_seed_simulation_fallback": true,
    "bootstrap_timeout_ms": 2500
  },
  "bot": {
    "threads": 4,
    "min_nodes": 4000,
    "max_nodes": 400000,
    "use_hold": true,
    "speculate": false,
    "movement_mode": "zero_g_safe",
    "spawn_rule": "row19_or20"
  },
  "handling": {
    "arr_ms": 0,
    "das_ms": 97,
    "dcd_ms": 0,
    "soft_drop_mode": "infinite",
    "allow_post_softdrop_actions": true,
    "allow_post_softdrop_horizontal": false,
    "release_after_each_action": true,
    "action_settle_ms": 0,
    "soft_drop_factor": 1,
    "prevent_accidental_hard_drops": true,
    "cancel_das_on_direction_change": true,
    "prefer_soft_drop_over_movement": false,
    "irs_mode": "off",
    "ihs_mode": "off"
  },
  "keys": {
    "left": "LEFT",
    "right": "RIGHT",
    "rotate_cw": "X",
    "rotate_ccw": "Z",
    "hold": "C",
    "soft_drop": "DOWN",
    "hard_drop": "SPACE"
  }
}
